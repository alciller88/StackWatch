{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "declaration": true,
    "composite": true
  },
  "include": ["electron/**/*.ts", "shared/**/*.ts", "src/utils/healthScore.ts"],
  "exclude": ["electron/analyzers/__tests__/fixtures/**"]
}
