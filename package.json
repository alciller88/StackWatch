{
  "name": "stackwatch",
  "version": "0.1.0",
  "description": "Know your stack, own your stack. Visualize every service, dependency, and account your project depends on.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.node.json && wait-on http://localhost:5173 && node scripts/launch-electron.js\"",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "test": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reactflow": "^11.11.4",
    "@dagrejs/dagre": "^1.1.4",
    "zustand": "^5.0.3",
    "@octokit/rest": "^21.1.1",
    "electron-store": "^10.0.1",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^35.1.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.14",
    "@tailwindcss/vite": "^4.0.14",
    "vitest": "^3.0.7",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/node": "^22.13.10",
    "@types/js-yaml": "^4.0.9",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.3"
  },
  "author": "",
  "license": "MIT"
}
