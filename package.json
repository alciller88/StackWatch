{
  "name": "stackwatch",
  "version": "0.5.0",
  "description": "Know your stack, own your stack. Visualize every service, dependency, and account your project depends on.",
  "main": "dist-electron/electron/main.js",
  "bin": {
    "stackwatch": "./dist-cli/cli/index.js"
  },
  "files": [
    "dist-cli/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.node.json && wait-on http://localhost:5173 && node scripts/launch-electron.js\"",
    "build": "npm run build:dist",
    "build:prod": "tsc -p tsconfig.node.json && vite build",
    "build:dist": "npm run build:prod && electron-builder",
    "test": "vitest",
    "preview": "vite preview",
    "lint": "eslint src/ electron/ shared/",
    "build:cli": "tsc -p cli/tsconfig.json",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"shared/**/*.ts\"",
    "validate": "node scripts/validate-build.js",
    "release": "npm run validate && git tag v$(node -p \"require('./package.json').version\") && git push origin --tags"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@octokit/rest": "^21.1.1",
    "@tanstack/react-virtual": "^3.13.23",
    "dotenv": "^16.4.7",
    "electron-store": "^10.0.1",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.2.2",
    "vitest": "^3.0.7",
    "wait-on": "^8.0.3"
  },
  "author": "",
  "license": "MIT"
}
